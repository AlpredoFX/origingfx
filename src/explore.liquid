---
layout: layout.liquid
title: Explore — OriginGFX
pagination:
  data: data.artworks
  size: 8
  alias: paginatedArtworks
  reverse: true
permalink: "/explore/{% if pagination.pageNumber > 0 %}page-{{ pagination.pageNumber | plus: 1 }}/{% endif %}"
---

<section class="page-hero reveal">
    <div class="container center">
        <h1>Explore Artworks</h1>
        <p class="lead">Temukan karya terbaik dari para kreator Minecraft</p>
    </div>
</section>

<section class="section reveal">
    <div class="container">
        <div class="filter-bar">
            <button class="filter-btn active">All</button>
            <button class="filter-btn">Manip</button>
            <button class="filter-btn">Abstract</button>
            <button class="filter-btn">Art</button>
            <button class="filter-btn">Scene</button>
            <button class="filter-btn">Horror</button>
        </div>

        <div class="grid grid-4">
            {% for artwork in paginatedArtworks %}
            <div class="card" data-category="{{ artwork.category }}">
                <div class="thumb" style="background-image: url('{{ artwork.image }}'); background-size: cover; background-position: center;"></div>
                <h3>{{ artwork.title }}</h3>
                <p>by {{ artwork.artist }}</p>
                <a href="/artwork/{{ artwork.slug }}" class="card-link">View Artwork →</a>
            </div>
            {% endfor %}
        </div>

        <!-- ====== PAGINATION ====== -->
        <div class="pagination">
            <!-- Previous -->
            {% if pagination.href.previous %}
                <a href="{{ pagination.href.previous }}" class="page-btn">← Previous</a>
            {% else %}
                <span class="page-btn disabled">← Previous</span>
            {% endif %}

            <!-- Nomor Halaman -->
            {% for pageUrl in pagination.hrefs %}
                {% if pageUrl == pagination.href.current %}
                    <span class="page-btn active">{{ forloop.index }}</span>
                {% else %}
                    <a href="{{ pageUrl }}" class="page-btn">{{ forloop.index }}</a>
                {% endif %}
            {% endfor %}

            <!-- Next -->
            {% if pagination.href.next %}
                <a href="{{ pagination.href.next }}" class="page-btn">Next →</a>
            {% else %}
                <span class="page-btn disabled">lanjut njing →</span>
            {% endif %}
        </div>
        <!-- ====== END PAGINATION ====== -->

    </div>
</section>