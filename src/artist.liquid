---
layout: layout.liquid
title: "{{ artist.name }} — OriginGFX"
pagination:
  data: data.artists
  size: 1
  alias: artist
permalink: "/artist/{{ artist.slug }}/"
---

<section class="section reveal" style="padding-top: 40px;">
    <div class="container">
        <!-- Back Link -->
        <a href="#" class="back-link" onclick="history.back(); return false;">← Back</a>

        <!-- ====== PROFILE HEADER ====== -->
        <div class="artist-profile-header">
            <div class="profile-avatar-wrapper">
                {% if artist.avatar %}
                    <img src="{{ artist.avatar | url }}" alt="{{ artist.name }}" class="profile-avatar-img" loading="lazy">
                {% else %}
                    <div class="profile-avatar-placeholder">{{ artist.name | slice: 0, 1 }}</div>
                {% endif %}
            </div>

            <div class="profile-info">
                <h1>{{ artist.name }}</h1>
                <p class="profile-role">{{ artist.role }}</p>

                <div class="profile-stats">
                    {% assign artistArtworks = data.artworks | where: "artistSlug", artist.slug | size %}
                    <span class="profile-stat">
                        <span class="stat-number">{{ artistArtworks }}</span>
                        <span class="stat-label">Artworks</span>
                    </span>
                </div>
            </div>
        </div>

        <!-- ====== BIO ====== -->
        <div class="profile-bio-section">
            <h2>About</h2>
            <p>{{ artist.bio }}</p>
           
        </div>
            <p class="artist-price">{{ artist.price }}</p>
        <div class="artist-contact-buttons">
            {% if artist.social.instagram %}
                <a href="{{ artist.social.instagram }}" target="_blank" class="btn">Commission via Instagram</a>
            {% endif %}
            {% if artist.social.discord %}
                <a href="{{ artist.social.discord }}" target="_blank" class="btn">Commission via Discord</a>
            {% endif %}
            {% if artist.social.fiverr %}
                <a href="{{ artist.social.fiverr }}" target="_blank" class="btn">Commission via Fiverr</a>
            {% endif %}
        </div>

        <!-- ====== PORTFOLIO ====== -->
        <div class="profile-portfolio">
            <h2>Portfolio</h2>
            <div class="grid grid-3">
                {% assign artistArtworks = data.artworks | where: "artistSlug", artist.slug %}
                {% for artwork in artistArtworks %}
                <div class="card">
                    <div class="thumb" style="background-image: url('{{ artwork.image }}'); background-size: cover; background-position: center;"></div>
                    <h3>{{ artwork.title }}</h3>
                    <p>{{ artwork.year }}</p>
                    <a href="/artwork/{{ artwork.slug }}" class="card-link">View Artwork →</a>
                </div>
                {% else %}
                <p class="no-artwork">Belum ada artwork yang dipublikasikan.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</section>