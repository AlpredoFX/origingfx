<section class="page-hero reveal">
    <div class="container center">
        <h1>Contact Us</h1>
        <p class="lead">Hubungi kami untuk pertanyaan, kolaborasi, atau sekadar menyapa</p>
    </div>
</section>

<section class="section reveal">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info">
                <h2>Let's Connect</h2>
                <p>Kami senang mendengar dari kamu. Jangan ragu untuk menghubungi kami melalui salah satu platform di bawah ini.</p>

                <div class="contact-methods">
                    <div class="contact-method">
                        <span>📧</span>
                        <div>
                            <h4>Email</h4>
                            <a href="mailto:hello@origingfx.com">hello@origingfx.com</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <span>💬</span>
                        <div>
                            <h4>Discord</h4>
                            <a href="#">@origingfx</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <span>🛒</span>
                        <div>
                            <h4>Fiverr</h4>
                            <a href="#">OriginGFX on Fiverr</a>
                        </div>
                    </div>
                    <div class="contact-method">
                        <span>📱</span>
                        <div>
                            <h4>Instagram</h4>
                            <a href="#">@origingfx</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contact-form">
                <h2>Send a Message</h2>
                <form>
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input type="text" id="name" placeholder="Your name">
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" placeholder="your@email.com">
                    </div>
                    <div class="form-group">
                        <label for="subject">Subject</label>
                        <input type="text" id="subject" placeholder="What's this about?">
                    </div>
                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" rows="5" placeholder="Tell us more..."></textarea>
                    </div>
                    <button type="submit" class="btn">Send Message</button>
                </form>
            </div>
        </div>
    </div>
</section>
