---
layout: layout.liquid
title: Artists — OriginGFX
---

<section class="page-hero reveal">
    <div class="container center">
        <h1>Meet Our Artists</h1>
        <p class="lead">Kreator di balik setiap karya</p>
        <p class="hero-sub">Temukan dan kenali para artist di balik setiap artwork</p>
    </div>
</section>

<section class="section reveal visible section-short">
    <div class="container">
        <div class="artists-grid">
            {% for artist in data.artists %}
            <article class="artist-card">
                <!-- Avatar dengan fallback -->
                <div class="artist-avatar-wrapper" style="background-image: url('{{ artist.avatar }}'); background-size: cover; background-position: center;"></div>

                <div class="artist-card-content">
                    <h3>{{ artist.name }}</h3>
                    <p class="artist-role">{{ artist.role }}</p>

                    <div class="artist-stats">
                        {% assign artistArtworks = data.artworks | where: "artistSlug", artist.slug | size %}
                        <span class="artist-stat">
                            <span class="stat-number">{{ artistArtworks }}</span>
                            <span class="stat-label">Artworks</span>
                        </span>
                    </div>

                    <a href="/artist/{{ artist.slug }}" class="btn-portfolio">
                        <span>View Portfolio</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </article>
            {% endfor %}
        </div>

        <!-- Footer note -->
        <p class="artists-footer">Temukan lebih banyak artist di galeri OriginGFX</p>
        
        <!-- ====== SIGNATURE ====== -->
        <section class="section reveal section-signature">
            <div class="signature-section">
                <div class="signature-quote">
                    <span class="quote-mark">✦</span>
                    <p>Every artwork deserves to be discovered.</p>
                </div>
            </div>
        </section>
        
    </div>
</section>