---
layout: layout.liquid
title: Artists — OriginGFX
---

<section class="page-hero reveal">
    <div class="container center">
        <h1>Meet Our Artists</h1>
        <p class="lead">Kreator di balik setiap karya</p>
        <p class="hero-sub" style="font-size: 1rem; max-width: 500px; margin: 8px auto 0; color: var(--muted);">
            OriginGFX dimulai oleh satu artist, dan tumbuh bersama kreator lain yang ingin berbagi karya mereka.
        </p>
    </div>
</section>

<section class="section reveal" style="padding-top: 20px;">
    <div class="container">

        <!-- ====== STATISTIK ====== -->
        <div class="explore-stats artists-stats">
            <span class="stat-item">
                <span class="stat-number">{{ supabase.artists | size }}</span>
                <span class="stat-label">Artists</span>
            </span>
            <span class="stat-divider"></span>
            <span class="stat-item">
                <span class="stat-number">{{ supabase.artworks | size }}</span>
                <span class="stat-label">Artworks</span>
            </span>
            <span class="stat-divider"></span>
            <span class="stat-item">
                <span class="stat-number">{{ supabase.artworks | map: "category" | uniq | size }}</span>
                <span class="stat-label">Styles</span>
            </span>
        </div>

        <!-- ============================================================
            1. FOUNDER SPOTLIGHT
        ============================================================ -->
        {% assign founder = nil %}
        {% for a in supabase.artists %}
            {% if a.badge == "founder" %}
                {% assign founder = a %}
            {% endif %}
        {% endfor %}

        {% if founder %}
        <div class="founder-spotlight">
            <span class="section-label">✦ Founder</span>
            <div class="founder-spotlight-card">
                <div class="founder-spotlight-avatar" style="background-image: url('{{ founder.avatar }}'); background-size: cover; background-position: center;"></div>
                <div class="founder-spotlight-info">
                    <h3>{{ founder.name }}</h3>
                    <span class="founder-badge">Founder</span>
                    <p class="founder-role">{{ founder.identity | default: founder.role }}</p>
                    <div class="founder-spotlight-stats">
                        {% assign founderArtworks = supabase.artworks | where: "artist_id", founder.id | size %}
                        <span>{{ founderArtworks }} Artworks</span>
                        {% if founder.joined %}
                        <span>· Joined {{ founder.joined }}</span>
                        {% endif %}
                    </div>
                    <a href="/artist/{{ founder.slug }}" class="btn-portfolio" style="opacity:1; transform:none; padding:10px 28px;">
                        <span>View Profile</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
        {% endif %}

        <!-- ============================================================
            2. COMMUNITY ARTISTS — GRID 4 KOLOM
        ============================================================ -->
        <div class="community-section">
            <span class="section-label">Community Artists</span>
            <div class="artists-grid">
                {% for artist in supabase.artists %}
                    {% if artist.badge != "founder" %}
                    <article class="artist-card">
                        {% if artist.badge %}
                        <span class="artist-badge {{ artist.badge }}">
                            {% case artist.badge %}
                                {% when 'founder' %}👑 Founder
                                {% when 'featured' %}⭐ Featured
                                {% when 'new' %}🌱 New Artist
                                {% when 'verified' %}✔ Verified
                                {% when 'contributor' %}🤝 Contributor
                                {% when 'curator' %}🏛 Curator
                                {% when 'editors-pick' %}🏆 Editor's Pick
                                {% when 'community-favorite' %}❤️ Community Favorite
                            {% endcase %}
                        </span>
                        {% endif %}
                        <div class="artist-avatar-wrapper" style="background-image: url('{{ artist.avatar }}'); background-size: cover; background-position: center;"></div>
                        <div class="artist-card-content">
                            <h3>{{ artist.name }}</h3>
                            <p class="artist-identity">{{ artist.identity | default: artist.role }}</p>
                            <div class="artist-stats">
                                {% assign artistArtworks = supabase.artworks | where: "artist_id", artist.id | size %}
                                <span class="artist-stat">
                                    <span class="stat-number">{{ artistArtworks }}</span>
                                    <span class="stat-label">Artworks</span>
                                </span>
                                {% if artist.joined %}
                                <span class="artist-stat">
                                    <span class="stat-label">Joined {{ artist.joined }}</span>
                                </span>
                                {% endif %}
                            </div>
                            {% if artistArtworks > 0 %}
                            <a href="/artist/{{ artist.slug }}" class="btn-portfolio">
                                <span>View Profile</span>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </a>
                            {% else %}
                            <span class="artist-empty">Coming Soon</span>
                            {% endif %}
                        </div>
                    </article>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <!-- ============================================================
            3. FUTURE ARTISTS / JOIN
        ============================================================ -->
        <div class="artists-closing">
            <div class="future-artists">
                <span class="section-label">✦ Future Artists</span>
                <p class="future-text">
                    OriginGFX terus tumbuh. Jika kamu seorang artist dan ingin bergabung, 
                    <a href="/contact">hubungi kami</a>.
                </p>
            </div>
        </div>

    </div>
</section>

<!-- ====== SIGNATURE ====== -->
<section class="section reveal section-signature">
    <div class="signature-section">
         <div class="signature-quote">
            <span class="quote-mark">✦</span>
            <p>Behind every artwork is a story worth knowing.</p>
        </div>
    </div>
</section>