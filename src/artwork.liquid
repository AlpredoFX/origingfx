---
layout: layout.liquid
title: "{{ artwork.title }} — OriginGFX"
pagination:
  data: data.artworks
  size: 1
  alias: artwork
permalink: "/artwork/{{ artwork.slug }}/"
---

<section class="section reveal" style="padding-top: 40px;">
    <div class="container">
        <!-- Back Link -->
        <a href="#" class="back-link" onclick="history.back(); return false;">← Back</a>

        <!-- ====== ARTWORK DETAIL ====== -->
        <div class="artwork-detail">
            <div class="artwork-image">
                <div class="artwork-placeholder" onclick="openLightbox('{{ artwork.image }}', '{{ artwork.title }}')">
                    <img src="{{ artwork.image }}" alt="{{ artwork.title }}" loading="lazy">
                    <div class="zoom-hint">🔍 Klik untuk memperbesar</div>
                </div>
            </div>

            <div class="artwork-info">
                <span class="artwork-tag">{{ artwork.category }}</span>
                <h1>{{ artwork.title }}</h1>
                <p class="artwork-artist">by <a href="/artist/{{ artwork.artistSlug }}">{{ artwork.artist }}</a></p>

                <div class="artwork-meta">
                    <span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ artwork.year }}
                    </span>
                    <span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                        {{ artwork.software | join: ", " }}
                    </span>
                    <span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                        {{ artwork.category }}
                    </span>
                </div>

                <div class="artwork-description">
                    <p>{{ artwork.description }}</p>
                </div>

                <div class="artwork-actions">
                    <a href="#" class="btn">Commission Artist</a>
                    <a href="#" class="btn btn-outline">Save Artwork</a>
                </div>

                <div class="artwork-social">
                    <span>Share:</span>
                    <a href="#">Twitter</a>
                    <a href="#">Instagram</a>
                    <a href="#">Pinterest</a>
                </div>
            </div>
        </div>

        <!-- ====== RELATED ARTWORKS ====== -->
        <div class="related-artworks">
            <h3>Related Artworks</h3>
            <div class="grid grid-3">
                {% assign allArtworks = data.artworks %}
                {% assign related = "" | split: "" %}
                {% for a in allArtworks %}
                    {% if a.artistSlug == artwork.artistSlug and a.slug != artwork.slug %}
                        {% assign related = related | push: a %}
                    {% endif %}
                {% endfor %}
                {% assign relatedCount = related | size %}
                {% if relatedCount == 0 %}
                    {% assign fallback = allArtworks | reverse %}
                    {% for a in fallback limit: 3 %}
                        {% if a.slug != artwork.slug %}
                        <div class="card">
                            <div class="thumb" style="background-image: url('{{ a.image }}'); background-size: cover; background-position: center;"></div>
                            <h3>{{ a.title }}</h3>
                            <p>by {{ a.artist }}</p>
                            <a href="/artwork/{{ a.slug }}" class="card-link">View Artwork →</a>
                        </div>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    {% for a in related limit: 3 %}
                    <div class="card">
                        <div class="thumb" style="background-image: url('{{ a.image }}'); background-size: cover; background-position: center;"></div>
                        <h3>{{ a.title }}</h3>
                        <p>by {{ a.artist }}</p>
                        <a href="/artwork/{{ a.slug }}" class="card-link">View Artwork →</a>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</section>

<!-- ====== LIGHTBOX MODAL PREMIUM ====== -->
<div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <div class="lightbox-content" onclick="event.stopPropagation()">
        <!-- Close Button -->
        <button class="lightbox-close" onclick="closeLightbox()">✕</button>

        <!-- Zoom Controls -->
        <div class="lightbox-controls">
            <button class="zoom-btn" onclick="zoomIn()" title="Perbesar">＋</button>
            <button class="zoom-btn" onclick="zoomOut()" title="Perkecil">−</button>
            <button class="zoom-btn" onclick="resetZoom()" title="Reset">⟲</button>
        </div>

        <!-- Image Container (untuk zoom & drag) -->
        <div class="lightbox-image-container" id="lightbox-container">
            <img id="lightbox-img" src="" alt="">
        </div>

        <!-- Caption -->
        <p id="lightbox-caption" class="lightbox-caption"></p>

        <!-- Hint -->
        <p class="lightbox-hint">Scroll untuk zoom · Drag untuk geser</p>
    </div>
</div>
<!-- ====== END LIGHTBOX ====== -->