---
layout: layout.liquid
title: OriginGFX — Digital Gallery for Minecraft Artists
---

<section class="hero reveal">
    <div class="container center">
        <!-- ====== HERO VISUAL (Grid Mini Artwork) ====== -->
        <div class="hero-grid">
            {% assign featuredArtworks = supabase.artworks | slice: 0, 4 %}
            {% for artwork in featuredArtworks %}
            <div class="hero-thumb" style="background-image: url('{{ artwork.image }}'); background-size: cover; background-position: center;"></div>
            {% endfor %}
        </div>

        <!-- ====== HERO TEXT ====== -->
        <h1>Digital Gallery for <br>Minecraft Artists</h1>

        <p class="lead">Gallery First. Store Second. Artist Always.</p>

        <p class="hero-sub">Menampilkan karya terbaik dari para kreator Minecraft</p>

        <!-- ====== STATISTIK ====== -->
        <div class="hero-stats">
            <div class="hero-stat">
                <span class="hero-stat-number">{{ supabase.artists | size }}</span>
                <span class="hero-stat-label">Artists</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <span class="hero-stat-number">{{ supabase.artworks | size }}</span>
                <span class="hero-stat-label">Artworks</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
                <span class="hero-stat-number">✦</span>
                <span class="hero-stat-label">Curated</span>
            </div>
        </div>

        <a class="btn" href="/explore">Explore Gallery</a>
    </div>
</section>

<!-- ====== FEATURED SHOWCASE ====== -->
<section id="featured" class="section reveal">
    <div class="container">
        <div class="section-head">
            <span>01</span>
            <h2>Featured Showcase</h2>
        </div>

        {% assign featuredArtwork = supabase.artworks | where: "slug", data.featured | first %}

        {% if featuredArtwork %}
            <a href="/artwork/{{ featuredArtwork.slug }}" class="featured-wrapper">
                <div class="featured-image" style="background-image: url('{{ featuredArtwork.image }}'); background-size: cover; background-position: center;">
                    <div class="featured-overlay">
                        <div class="featured-content">
                            <div class="featured-badge-wrapper">
                                <span class="featured-badge-line"></span>
                                <span class="featured-badge">✦ Featured</span>
                                <span class="featured-badge-line"></span>
                            </div>
                            <h3>{{ featuredArtwork.title }}</h3>
                            <p>by {{ featuredArtwork.artist }}</p>
                            <span class="featured-link">View Artwork →</span>
                        </div>
                    </div>
                </div>
            </a>
        {% else %}
            <p class="featured-error">Belum ada artwork yang dipilih sebagai featured.</p>
        {% endif %}
    </div>
</section>

<!-- ====== LATEST UPLOADS ====== -->
<section class="section reveal">
    <div class="container">
        <div class="section-head">
            <span>02</span>
            <h2>Latest Uploads</h2>
            <a href="/explore" class="section-more">View all →</a>
        </div>
        <div class="grid">
            {% assign sortedArtworks = supabase.artworks | sort: "created_at" | reverse %}
            {% assign latestArtworks = sortedArtworks | slice: 0, 3 %}
            {% for item in latestArtworks %}
            <div class="card">
                <div class="thumb" style="background-image: url('{{ item.image }}'); background-size: cover; background-position: center;"></div>
                <h3>{{ item.title }}</h3>
                <p>by {{ item.artist }}</p>
                <a href="/artwork/{{ item.slug }}" class="card-link">View Artwork →</a>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ====== FEATURED ARTIST ====== -->
{% assign featuredArtist = supabase.artists | where: "badge", "featured" | first %}
{% if featuredArtist %}
<section class="section reveal" style="padding-top: 20px;">
    <div class="container">
        <div class="section-head">
            <span>✦</span>
            <h2>Featured Artist</h2>
        </div>
        <div class="featured-artist-card">
            <div class="featured-artist-avatar" style="background-image: url('{{ featuredArtist.avatar }}'); background-size: cover; background-position: center;"></div>
            <div class="featured-artist-info">
                <h3>{{ featuredArtist.name }}</h3>
                <p class="featured-artist-role">{{ featuredArtist.role }}</p>
                <p class="featured-artist-bio">{{ featuredArtist.bio | truncate: 120 }}</p>
                <a href="/artist/{{ featuredArtist.slug }}" class="btn">View Profile →</a>
            </div>
        </div>
    </div>
</section>
{% endif %}

<!-- ====== MEET OUR ARTISTS ====== -->
<section class="section reveal visible section-short">
    <div class="container">
        <div class="section-head">
            <span>03</span>
            <h2>Meet Our Artists</h2>
            <a href="/artists" class="section-more">View all →</a>
        </div>

        <div class="artists-list">
            <!-- Ambil artist yang is_featured = true, kalau tidak ada ambil 3 artist pertama -->
            {% assign featuredArtists = supabase.artists | where: "is_featured", true %}
            {% if featuredArtists.size == 0 %}
                {% assign featuredArtists = supabase.artists | slice: 0, 3 %}
            {% endif %}

            {% for artist in featuredArtists %}
                {% assign artistArtworks = supabase.artworks | where: "artist_id", artist.id | size %}
                <article class="artist-item">
                    <div class="artist-meta">
                        <h3>{{ artist.name }}</h3>
                        <p>{{ artist.role }}</p>
                    </div>
                    <div class="artist-info">
                        <span>{{ artistArtworks }} Artworks</span>
                        <a href="/artist/{{ artist.slug }}">View Portfolio →</a>
                    </div>
                </article>
            {% endfor %}
        </div>

        <!-- ====== SIGNATURE ====== -->
        <section class="section reveal section-signature">
            <div class="signature-section">
                <div class="signature-quote">
                    <span class="quote-mark">✦</span>
                    <p>Every artwork deserves to be discovered.</p>
                </div>
            </div>
        </section>

    </div>
</section>