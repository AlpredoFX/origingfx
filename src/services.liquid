---
layout: layout.liquid
title: Commission Hub — OriginGFX
---

<section class="page-hero reveal">
    <div class="container center">
        <h1>Commission Hub</h1>
        <p class="lead">Find artists based on the type of work you need</p>
        <p class="hero-sub">Temukan artist yang sesuai dengan kebutuhanmu</p>
    </div>
</section>

<section class="section reveal">
    <div class="container">

        <div class="services-grid">
            {% for service in data.services %}
            <div class="service-card">
                <div class="service-icon">
                    {{ service.icon }}
                </div>
                <h3>{{ service.name }}</h3>
                <p>{{ service.description }}</p>

                {% assign artists = supabase.artists | where: "services", service.slug %}
                {% assign artistCount = artists | size %}
                <p class="service-artist-count">{{ artistCount }} Artists Available</p>

                <a href="/artists?service={{ service.slug }}" class="service-link">
                    Meet the Artists →
                </a>
            </div>
            {% endfor %}
        </div>

    </div>
</section>

<!-- Signature -->
{% include "signature.liquid" with quote: "Great ideas become unforgettable visuals." %}